{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"files": {
		"includes": ["src/**/*.{ts,tsx}", "!src/routeTree.gen.ts"]
	},
	"linter": {
		"domains": {
			"react": "recommended"
		},
		"rules": {
			"a11y": "off",
			"complexity": {
				"useArrowFunction": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": "off"
			},
			"security": {
				"noDangerouslySetInnerHtml": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noImplicitAnyLet": "off"
			}
		}
	},
	"formatter": {
		"enabled": false
	},
	"assist": {
		"enabled": false
	}
}
